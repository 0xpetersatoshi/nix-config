{
  "model": "openai/gpt-5.3-codex",
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "experimental": {
    "hook": {
      "session.idle": [
        {
          "command": ["notify-send", "-u", "normal", "-a", "opencode", "opencode", "Agent is idle — your turn"]
        },
        {
          "command": ["pw-play", "/run/current-system/sw/share/sounds/freedesktop/stereo/complete.oga"]
        }
      ],
      "permission.ask": [
        {
          "command": ["notify-send", "-u", "critical", "-a", "opencode", "opencode", "Permission requested"]
        },
        {
          "command": ["pw-play", "/run/current-system/sw/share/sounds/freedesktop/stereo/dialog-information.oga"]
        }
      ]
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "{env:OLLAMA_BASE_URL}",
        "apiKey": "ollama"
      },
      "models": {
        "qwen3.6-coder:27b": {
          "name": "Qwen 3.6 27B (no-think, 64k ctx)",

          "tools": true,
          "reasoning": false,

          "options": {
            "reasoningEffort": "none",
            "num_ctx": 65536,
            "temperature": 0.7,
            "top_p": 0.8,
            "presence_penalty": 1.5
          }
        }
      }
    }
  }
}
